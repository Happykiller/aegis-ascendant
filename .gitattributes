# Normalize to LF (dev in WSL); Godot text resources must stay LF
* text=auto eol=lf
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.godot text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.csv text eol=lf
# PowerShell runs on Windows
*.ps1 text eol=crlf
# Binaries
*.png filter=lfs diff=lfs merge=lfs -text
*.glb filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
