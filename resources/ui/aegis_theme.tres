[gd_resource type="Theme" load_steps=6 format=3]

; Thème partagé de l'interface. Le projet n'en avait aucun : chaque écran
; redéclarait ses couleurs en theme_override_*, et TROIS cyans divergents
; coexistaient (HUD #29E6FF, options #3FD9E8, titre #2F9CAA). Celui du HUD fait
; foi — c'est le seul écran réellement travaillé.
;
; La recette de cadre vient de fighter_hud.gd:60-83 : fond #060A14 à 82 %,
; bordure de 3 px, ANGLES VIFS (corner radius 0 — c'est une borne d'arcade, pas
; une application), et une ombre portée décalée de 4 px teintée de la bordure.

[ext_resource type="FontFile" uid="uid://t4pdnm2uxan5" path="res://assets/fonts/PressStart2P.ttf" id="1_label"]

; Item de menu au repos : aucun cadre. Seul l'item survolé/sélectionné se
; matérialise — sinon la liste devient un mur de rectangles et le curseur ne
; se lit plus.
[sub_resource type="StyleBoxFlat" id="btn_normal"]
bg_color = Color(0.024, 0.039, 0.078, 0)
border_width_left = 3
border_color = Color(0.161, 0.902, 1, 0)

[sub_resource type="StyleBoxFlat" id="btn_hover"]
bg_color = Color(0.024, 0.039, 0.078, 0.82)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.161, 0.902, 1, 1)
shadow_color = Color(0.161, 0.902, 1, 0.25)
shadow_size = 0
shadow_offset = Vector2(4, 4)

[sub_resource type="StyleBoxFlat" id="btn_pressed"]
