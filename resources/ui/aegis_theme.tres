border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.6, 0.96, 1, 1)

[sub_resource type="StyleBoxFlat" id="panel"]
bg_color = Color(0.024, 0.039, 0.078, 0.82)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.161, 0.902, 1, 1)
shadow_color = Color(0.161, 0.902, 1, 0.25)
shadow_size = 0
shadow_offset = Vector2(4, 4)

[resource]
