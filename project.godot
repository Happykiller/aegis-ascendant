; Engine configuration file — Aegis Ascendant (Godot 4.7-stable).
; Managed by hand (no GUI editor in WSL); keep keys documented and minimal.

config_version=5

[application]

config/name="Aegis Ascendant"
config/version="0.1.0"
run/main_scene="res://scenes/boot/boot.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/game_state.gd"
SceneRouter="*res://scripts/core/scene_router.gd"
AudioManager="*res://scripts/core/audio_manager.gd"

[audio]

buses/default_bus_layout="res://resources/audio/default_bus_layout.tres"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[rendering]

renderer/rendering_method="forward_plus"
