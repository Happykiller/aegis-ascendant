[node name="Codex" type="Node3D"]
script = ExtResource("1_codex")

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = ExtResource("4_env")

; Le fond du bestiaire n'est PAS reglé ici : codex_screen.gd le pose en code, sur une
; COPIE du materiau. Le ShaderMaterial vit sur le PlaneMesh de la scene instanciee et
; il est partage avec le combat — le retoucher dans cette scene le retoucherait aussi
; en vol (meme piege que title_stage.gd).
[node name="SpaceBackdrop" parent="." instance=ExtResource("5_backdrop")]

; La caméra plonge de 8° : un présentoir vu strictement de face aplatit la coque, et
; le regard d'un catalogue technique vient toujours d'un peu au-dessus.
; La DISTANCE, elle, est posée en code — elle dépend de la taille de la coque montée.
[node name="CameraRig" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.99027, -0.13917, 0, 0.13917, 0.99027, 0, 0, 0)

[node name="Camera3D" type="Camera3D" parent="CameraRig"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 6)
current = true
fov = 45.0

; Éclairage trois points repris de l'accueil, à l'identique. C'est celui qui relève
; les fuselages que l'éclairage de combat laisse dans le noir (BACKLOG : « les coques
; lisent beaucoup plus sombre en jeu qu'en rendu studio ») — et un catalogue dont les
; coques sont sombres ne catalogue rien.
[node name="KeyLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.8192, 0.4698, -0.329, 0, 0.5736, 0.8192, 0.5736, -0.671, 0.4698, 0, 12, 0)
light_color = Color(1, 0.976, 0.925, 1)
light_energy = 1.55
shadow_enabled = true
directional_shadow_mode = 0
directional_shadow_max_distance = 60.0

[node name="RimLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(-0.9962, -0.0298, 0.0819, 0, 0.9397, 0.342, -0.0872, 0.3407, -0.9361, 0, 10, -6)
light_color = Color(0.596, 0.855, 1, 1)
light_energy = 0.7
shadow_enabled = false

[node name="FillLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.895, -0.2012, 0.4, 0, 0.8943, 0.449, -0.448, -0.4019, 0.799, 0, 6, 8)
light_color = Color(0.85, 0.91, 1, 1)
light_energy = 0.55
shadow_enabled = false

; Le plateau tournant, en DEUX etages. Tilt porte le tangage, Yaw le lacet : dans cet
; ordre-la, et pas l'inverse, la coque bascule autour de l'axe horizontal de l'ECRAN
; quel que soit son lacet. La coque est montee sous Yaw, en code.
[node name="Tilt" type="Node3D" parent="."]

[node name="Yaw" type="Node3D" parent="Tilt"]

[node name="ScreenCapture" type="Node" parent="."]
script = ExtResource("3_capture")

[node name="RetroPost" type="CanvasLayer" parent="."]
layer = -1

[node name="Effect" type="ColorRect" parent="RetroPost"]
material = SubResource("mat_retro")
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

; La fiche se construit entièrement en code (codex_datasheet.gd) : ses libellés, ses
; valeurs et jusqu'à sa couleur d'accent changent à chaque coque.
[node name="Datasheet" type="CanvasLayer" parent="."]
script = ExtResource("2_sheet")

[node name="Scanlines" type="CanvasLayer" parent="."]
layer = 5

[node name="Effect" type="ColorRect" parent="Scanlines"]
material = SubResource("mat_scan")
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
