[gd_scene load_steps=8 format=3]

; Écran de victoire / résultats — reforgé dans le langage de l'accueil (ADR-0012),
; comme l'écran de pause avant lui.
;
; L'ancienne version posait `victory_frame.svg` en TextureRect plein cadre et des
; labels en police Godot PAR DÉFAUT — le thème n'était pas appliqué, les textes
; étaient en anglais alors que tout le reste de l'interface est en français, et il
; n'y avait aucun bouton : « PRESS ENTER TO REPLAY » était la seule sortie, et elle
; ne menait qu'à un rechargement sec.
;
; Le mobilier de l'accueil est reconduit aux mêmes ancres. La variation propre à cet
; écran est son ENCADRÉ DE RAPPORT : c'est un débriefing, il porte des chiffres.

[ext_resource type="Script" path="res://scripts/ui/mission_report.gd" id="1_report"]
[ext_resource type="Theme" path="res://resources/ui/aegis_theme.tres" id="2_theme"]
[ext_resource type="Texture2D" path="res://assets/imported/ui/helios_vanguard_emblem.svg" id="3_emblem"]
[ext_resource type="Script" path="res://scripts/ui/comms_trace.gd" id="4_trace"]
[ext_resource type="Shader" path="res://shaders/scanlines.gdshader" id="5_scan"]

[sub_resource type="ShaderMaterial" id="mat_scan"]
shader = ExtResource("5_scan")
shader_parameter/line_alpha = 0.18
shader_parameter/period = 4.0

[sub_resource type="StyleBoxFlat" id="frame"]
bg_color = Color(0, 0, 0, 0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.161, 0.902, 1, 0.3)

[node name="MissionReport" type="CanvasLayer"]
layer = 30
script = ExtResource("1_report")

[node name="Scrim" type="ColorRect" parent="."]
unique_name_in_owner = true
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.027, 0.039, 0.071, 0.78)
mouse_filter = 2

[node name="Overlay" type="Control" parent="."]
unique_name_in_owner = true
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

[node name="Frame" type="Panel" parent="Overlay"]
theme_override_styles/panel = SubResource("frame")
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 22.0
offset_top = 22.0
offset_right = -22.0
offset_bottom = -22.0
mouse_filter = 2

[node name="Identity" type="VBoxContainer" parent="Overlay"]
offset_left = 52.0
offset_top = 48.0
offset_right = 620.0
offset_bottom = 140.0
theme_override_constants/separation = 8
mouse_filter = 2

[node name="Emblem" type="TextureRect" parent="Overlay/Identity"]
custom_minimum_size = Vector2(46, 46)
size_flags_horizontal = 0
mouse_filter = 2
texture = ExtResource("3_emblem")
expand_mode = 3
stretch_mode = 5

[node name="Faction" type="Label" parent="Overlay/Identity"]
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.894, 0.71, 0.29, 0.92)
theme_override_font_sizes/font_size = 13
text = "HELIOS VANGUARD"

[node name="Program" type="Label" parent="Overlay/Identity"]
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.875, 0.965, 1, 0.62)
theme_override_font_sizes/font_size = 10
text = "ASCENDANT PROGRAM"

[node name="Unit" type="Label" parent="Overlay/Identity"]
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.161, 0.902, 1, 0.75)
theme_override_font_sizes/font_size = 10
text = "HV-09  //  SPECTER-9"

; Bande plus haute que sur l'accueil et la pause : cet écran porte deux blocs de plus
; (l'encadré de rapport et un bouton supplémentaire). Le titre reste néanmoins à la
; même hauteur, parce que c'est par le HAUT que la bande est calée.
[node name="Center" type="VBoxContainer" parent="Overlay"]
unique_name_in_owner = true
anchor_left = 0.5
anchor_right = 0.5
offset_left = -540.0
offset_top = 200.0
offset_right = 540.0
offset_bottom = 880.0
theme_override_constants/separation = 16
alignment = 1
mouse_filter = 2

[node name="Kicker" type="Label" parent="Overlay/Center"]
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.161, 0.902, 1, 0.85)
theme_override_font_sizes/font_size = 14
text = "HELIOS VANGUARD  //  RAPPORT DE MISSION"
horizontal_alignment = 1

; Or, et non blanc comme PAUSE : la DA (§5.1) réserve l'or au commandement et aux
; fonctions exceptionnelles. Une victoire en est une — et l'écran se distingue de la
; pause au premier coup d'œil, sans changer de grammaire.
[node name="Title" type="Label" parent="Overlay/Center"]
unique_name_in_owner = true
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.988, 0.902, 0.71, 1)
theme_override_colors/font_shadow_color = Color(0.894, 0.71, 0.29, 0.5)
theme_override_constants/shadow_offset_x = 0
theme_override_constants/shadow_offset_y = 0
theme_override_constants/shadow_outline_size = 10
theme_override_font_sizes/font_size = 54
text = "VICTOIRE"
horizontal_alignment = 1

[node name="Tagline" type="Label" parent="Overlay/Center"]
unique_name_in_owner = true
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.161, 0.902, 1, 0.9)
theme_override_font_sizes/font_size = 15
text = "PALE LEVIATHAN DETRUIT  ·  SECTEUR SECURISE"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Overlay/Center"]
custom_minimum_size = Vector2(0, 20)
mouse_filter = 2

; La variation propre à cet écran. Recette de cadre du thème (fond #060A14 à 82 %,
; bordure cyan de 3 px, angles vifs), désormais atteignable pour un PanelContainer.
[node name="Readout" type="PanelContainer" parent="Overlay/Center"]
custom_minimum_size = Vector2(460, 0)
size_flags_horizontal = 4
theme = ExtResource("2_theme")

[node name="Pad" type="MarginContainer" parent="Overlay/Center/Readout"]
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 18
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 18

[node name="Rows" type="VBoxContainer" parent="Overlay/Center/Readout/Pad"]
theme_override_constants/separation = 14

[node name="ScoreRow" type="HBoxContainer" parent="Overlay/Center/Readout/Pad/Rows"]

[node name="Name" type="Label" parent="Overlay/Center/Readout/Pad/Rows/ScoreRow"]
size_flags_horizontal = 3
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.875, 0.965, 1, 0.72)
theme_override_font_sizes/font_size = 14
text = "SCORE"

[node name="ScoreValue" type="Label" parent="Overlay/Center/Readout/Pad/Rows/ScoreRow"]
unique_name_in_owner = true
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.95, 0.98, 1, 1)
theme_override_font_sizes/font_size = 22
text = "00000000"
horizontal_alignment = 2

[node name="RankRow" type="HBoxContainer" parent="Overlay/Center/Readout/Pad/Rows"]

[node name="Name" type="Label" parent="Overlay/Center/Readout/Pad/Rows/RankRow"]
size_flags_horizontal = 3
size_flags_vertical = 4
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.875, 0.965, 1, 0.72)
theme_override_font_sizes/font_size = 14
text = "RANG"

[node name="RankValue" type="Label" parent="Overlay/Center/Readout/Pad/Rows/RankRow"]
unique_name_in_owner = true
theme = ExtResource("2_theme")
theme_override_colors/font_color = Color(0.894, 0.71, 0.29, 1)
theme_override_font_sizes/font_size = 30
text = "S"
horizontal_alignment = 2

[node name="Spacer2" type="Control" parent="Overlay/Center"]
custom_minimum_size = Vector2(0, 20)
mouse_filter = 2

[node name="Menu" type="VBoxContainer" parent="Overlay/Center"]
unique_name_in_owner = true
theme_override_constants/separation = 10
alignment = 1

[node name="ReplayButton" type="Button" parent="Overlay/Center/Menu"]
unique_name_in_owner = true
custom_minimum_size = Vector2(460, 56)
size_flags_horizontal = 4
theme = ExtResource("2_theme")
text = "REJOUER"

[node name="TitleButton" type="Button" parent="Overlay/Center/Menu"]
custom_minimum_size = Vector2(460, 56)
size_flags_horizontal = 4
theme = ExtResource("2_theme")
text = "RETOUR AU TITRE"

; Troisième régime du même appareil : l'accueil est SECURE, la pause est HOLD, le
; rapport est DÉGAGÉ — canal rouvert, trace vivante, pastille verte.
[node name="Comms" type="VBoxContainer" parent="Overlay"]
anchor_top = 1.0
anchor_bottom = 1.0
offset_left = 52.0
offset_top = -132.0
offset_right = 340.0
offset_bottom = -46.0
theme_override_constants/separation = 4
mouse_filter = 2

[node name="Status" type="HBoxContainer" parent="Overlay/Comms"]
theme_override_constants/separation = 8
mouse_filter = 2

[node name="Pip" type="ColorRect" parent="Overlay/Comms/Status"]
unique_name_in_owner = true
custom_minimum_size = Vector2(9, 9)
