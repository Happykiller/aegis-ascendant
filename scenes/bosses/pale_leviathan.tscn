projectile = ExtResource("3_shot")
; Le module compose prend l'armement (quatre phases, quatre verbes) : le boss ne tire
; plus ses motifs generiques. Declare ICI et pas seulement pose par le module — `_ready`
; des enfants tourne avant celui du parent, et faire dependre le boss de cet ordre pour
; savoir s'il lit ses bouches generiques est un equilibre qu'un refactor casserait sans
; bruit (meme raison que le Choir Harvester).
external_attacks = true

; Le combat propre au Leviathan : plaques, noeuds gravitiques, epines, coeur. Il pose
; `LeviathanTuning` (les valeurs de gameplay, jamais en dur) et partage la meme munition
; `boss_shot` que les motifs generiques abandonnes — une seule Resource, aucune copie.
[node name="Combat" type="Node" parent="."]
script = ExtResource("4_combat")
tuning = ExtResource("5_tuning")
projectile = ExtResource("3_shot")
