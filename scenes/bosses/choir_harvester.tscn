; Declare ICI et pas seulement pose par le module : `_ready` des enfants tourne avant
; celui du parent, et faire dependre le boss de cet ordre pour savoir s'il doit lire
; ses bouches generiques est un equilibre qu'un refactor casserait sans bruit.
external_attacks = true

; Le combat propre au Harvester : trois appendices destructibles, iris, noyau.
;
; COMPOSITION — `BossController` garde ce qui est generique (entree, deplacement,
; roulis, PV, signaux HUD, mort) et sert toujours le Pale Leviathan. Ce module ne lui
; prend que deux choses : l'armement (`external_attacks`, pose par le module au
; montage) et la vulnerabilite du corps, fermee tant que l'iris ne s'ouvre pas.
;
; `projectile` reste renseigne sur le boss ET sur le module : le tir generique est
; desactive, mais c'est la meme munition que le module donne a la griffe a trois
; tetes — une seule Resource, deux lecteurs, aucune copie.
[node name="Combat" type="Node" parent="."]
script = ExtResource("4_combat")
tuning = ExtResource("5_tuning")
projectile = ExtResource("3_shot")
