[sub_resource type="ShaderMaterial" id="mat_retro"]
shader = ExtResource("11_retro")
shader_parameter/target_res = Vector2(960, 540)
shader_parameter/levels = 20.0
shader_parameter/dither_amount = 0.9
shader_parameter/saturation = 1.3
shader_parameter/contrast = 1.18
shader_parameter/warmth = 0.055

[sub_resource type="ShaderMaterial" id="mat_scan"]
shader = ExtResource("12_scan")
shader_parameter/line_alpha = 0.18
shader_parameter/period = 4.0

[sub_resource type="StyleBoxFlat" id="frame"]
bg_color = Color(0, 0, 0, 0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.161, 0.902, 1, 0.3)

[node name="TitleStage" type="Node3D"]
script = ExtResource("1_stage")

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = ExtResource("5_env")

; Les réglages de shader propres au titre (center_calm, scroll_speed) sont posés en
; CODE par title_stage.gd : le matériau vit sur le PlaneMesh de la scène instanciée,
; pas en material_override, et il est PARTAGÉ avec le fond du jeu. Le retoucher ici
; le retoucherait aussi en combat.
[node name="SpaceBackdrop" parent="." instance=ExtResource("6_backdrop")]

[node name="CameraDirector" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.7, 6)
script = ExtResource("4_camdir")

[node name="Camera3D" type="Camera3D" parent="CameraDirector"]
transform = Transform3D(1, 0, 0, 0, 0.9848, 0.1736, 0, -0.1736, 0.9848, 0, 0, 0)
current = true
fov = 62.0

[node name="KeyLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.8192, 0.4698, -0.329, 0, 0.5736, 0.8192, 0.5736, -0.671, 0.4698, 0, 12, 0)
light_color = Color(1, 0.976, 0.925, 1)
light_energy = 1.55
shadow_enabled = true
directional_shadow_mode = 0
directional_shadow_max_distance = 60.0

[node name="RimLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(-0.9962, -0.0298, 0.0819, 0, 0.9397, 0.342, -0.0872, 0.3407, -0.9361, 0, 10, -6)
light_color = Color(0.596, 0.855, 1, 1)
light_energy = 0.7
shadow_enabled = false

; Troisième lumière, absente du jeu. Elle vient de face-haut-droite, du côté de la
; caméra, et relève les fuselages que l'éclairage de combat laisse dans le noir
; (docs/BACKLOG.md : « les coques lisent beaucoup plus sombre en jeu qu'en rendu
; studio »). C'est le remplissage de l'éclairage trois points de render-hull.py.
[node name="FillLight" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.895, -0.2012, 0.4, 0, 0.8943, 0.449, -0.448, -0.4019, 0.799, 0, 6, 8)
light_color = Color(0.85, 0.91, 1, 1)
light_energy = 0.55
shadow_enabled = false

; La citadelle passe de FIGURANT a SUJET (reforge BRIEF-0032). Elle etait a -34 m,
; ou ses 62 712 triangles se resumaient a une tache claire. Rapprochee a -22 m, elle
; occupe reellement le tiers superieur gauche du cadre, et son detail se voit.
; Le Specter-9 reste au premier plan : c'est le heros, elle est la promesse.
[node name="Citadel" type="Node3D" parent="."]
transform = Transform3D(0.8829, 0, 0.4695, 0, 1, 0, -0.4695, 0, 0.8829, -7.2, 5.9, -22)

[node name="Hull" parent="Citadel" instance=ExtResource("8_citadel")]

[node name="Escorts" type="Node3D" parent="."]

