; Contour noir OBLIGATOIRE ici : cette ligne traverse la piste blanche du diorama,
; et l'or sur blanc y devenait illisible sur tout le tiers central (DA §6 : « aucun
; texte essentiel ne doit reposer sur une image chargée sans fond ou contour de
; séparation »). Le défaut ne venait pas des glyphes — PressStart2P a bien É et ← →.
[node name="Controls" type="Label" parent="TitleUI"]
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -78.0
offset_bottom = -54.0
theme = ExtResource("10_theme")
theme_override_colors/font_color = Color(0.894, 0.71, 0.29, 0.7)
theme_override_colors/font_outline_color = Color(0.008, 0.012, 0.027, 0.9)
theme_override_constants/outline_size = 6
theme_override_font_sizes/font_size = 10
text = "OPTIONS  O     ·     DEPLACEMENT  ← →     ·     TIR  ESPACE"
horizontal_alignment = 1
mouse_filter = 2

[node name="VersionLabel" type="Label" parent="TitleUI"]
unique_name_in_owner = true
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -48.0
offset_bottom = -28.0
theme = ExtResource("10_theme")
; Le tampon de version tombe lui aussi sur la piste blanche : en blanc pâle, monter
; l'opacité n'y changeait rien — c'était du blanc sur du blanc, et seul le contour
; le tenait. Il passe donc à l'or de la ligne de touches juste au-dessus, à une
; opacité plus basse : même famille, rang inférieur.
theme_override_colors/font_color = Color(0.894, 0.71, 0.29, 0.5)
theme_override_colors/font_outline_color = Color(0.008, 0.012, 0.027, 0.9)
theme_override_constants/outline_size = 6
theme_override_font_sizes/font_size = 9
text = "v0.1.0 — prototype"
horizontal_alignment = 1
mouse_filter = 2

[node name="Fade" type="ColorRect" parent="TitleUI"]
unique_name_in_owner = true
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 1)
mouse_filter = 2

